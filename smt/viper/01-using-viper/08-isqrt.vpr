method triple(x: Int) returns (r: Int)
  requires x > 0
  ensures r == 3 * x


method isqrt(x: Int) returns (r: Int)
  requires x >= 0
  ensures x >= r * r
  ensures x < (r+1) * (r+1)

method foo(a: Int) returns (b: Int)
  requires a > 0
  ensures b > a
{
  b := isqrt(a)
  b := triple(a)
}